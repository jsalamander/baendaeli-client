BAENDAELI_API_KEY: "your-api-key-here"
BAENDAELI_URL: "https://api.baendaeli.example.com"
DEFAULT_AMOUNT_CENTS: 2000
SUCCESS_OVERLAY_MILLIS: 10000
# Actuator configuration (Raspberry Pi GPIO)
ACTUATOR_ENABLED: false
ACTUATOR_ENA_PIN: "GPIO25"
ACTUATOR_IN1_PIN: "GPIO8"
ACTUATOR_IN2_PIN: "GPIO7"
# CRITICAL: Movement time used for BOTH extend and retract (must be identical for equal distance)
ACTUATOR_MOVEMENT_SECONDS: 2
ACTUATOR_PAUSE_SECONDS: 2
# IR ball detection (beam-break sensors)
IR_SENSOR_ENABLED: true
IR_SENSOR_1_PIN: "GPIO27"
IR_SENSOR_2_PIN: "GPIO17"
IR_SENSOR_DEBOUNCE_MS: 10
# Vibrator motor (H-bridge driver: IN3/IN4 direction, ENB PWM speed control)
VIBRATOR_ENABLED: false
VIBRATOR_IN3_PIN: "GPIO16"
VIBRATOR_IN4_PIN: "GPIO20"
VIBRATOR_ENB_PIN: "GPIO18"
# Pressure sensor (ADS1115 via I2C) for ball-loaded detection
# The sensor reads voltage on A0; a ball in the holder raises the pressure and thus the voltage.
PRESSURE_ENABLED: false
PRESSURE_I2C_BUS: "1"
PRESSURE_I2C_ADDR: 0x48
PRESSURE_THRESHOLD_VOLTS: 1.0
# Number of vibration cycles before declaring a jam ("Stau")
PRESSURE_MAX_VIBRA_CYCLES: 5
# Duration of each vibration pulse in milliseconds
PRESSURE_VIBRA_DURATION_MS: 3000